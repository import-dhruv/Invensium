# Railway Environment Variables Template
# Copy these to your Railway project's environment variables

# Database (automatically provided by Railway PostgreSQL addon)
DATABASE_URL=postgresql://username:password@host:port/database

# Application
NODE_ENV=production
PORT=3000

# JWT Configuration (REQUIRED - Generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secure-jwt-secret-key-here
JWT_EXPIRES_IN=7d

# Optional: Custom domain CORS (update after getting Railway domain)
# FRONTEND_URL=https://your-vercel-app.vercel.app