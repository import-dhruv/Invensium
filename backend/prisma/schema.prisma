generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ───────────────────────────────────────────────────────────────────

enum UserRole {
  INVENTORY_MANAGER
  WAREHOUSE_STAFF
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(WAREHOUSE_STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  otpTokens        OtpToken[]
  receipts         Receipt[]
  deliveryOrders   DeliveryOrder[]
  internalTransfers InternalTransfer[]
  stockAdjustments StockAdjustment[]
}

model OtpToken {
  id        String   @id @default(cuid())
  otp       String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── Products ───────────────────────────────────────────────────────────────

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

enum UnitOfMeasure {
  UNIT
  KG
  GRAM
  LITER
  METER
  BOX
  PACK
  DOZEN
  TON
}

model Product {
  id          String        @id @default(cuid())
  name        String
  sku         String        @unique
  categoryId  String?
  category    Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  uom         UnitOfMeasure @default(UNIT)
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  stockLevels     StockLevel[]
  reorderRules    ReorderRule[]
  receiptLines    ReceiptLine[]
  deliveryLines   DeliveryLine[]
  transferLines   TransferLine[]
  adjustmentLines AdjustmentLine[]
  moveHistories   MoveHistory[]
}

// ─── Warehouse & Location ───────────────────────────────────────────────────

model Warehouse {
  id        String     @id @default(cuid())
  name      String     @unique
  address   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  locations Location[]
}

model Location {
  id          String    @id @default(cuid())
  name        String
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  stockLevels          StockLevel[]
  reorderRules         ReorderRule[]
  receipts             Receipt[]
  deliveryOrders       DeliveryOrder[]
  transfersFrom        InternalTransfer[] @relation("TransferFrom")
  transfersTo          InternalTransfer[] @relation("TransferTo")
  stockAdjustments     StockAdjustment[]
  moveHistoriesFrom    MoveHistory[]      @relation("MoveFrom")
  moveHistoriesTo      MoveHistory[]      @relation("MoveTo")

  @@unique([name, warehouseId])
}

// ─── Stock ──────────────────────────────────────────────────────────────────

model StockLevel {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  quantity   Float    @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([productId, locationId])
}

model ReorderRule {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  minQuantity Float
  maxQuantity Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, locationId])
}

// ─── Operations ─────────────────────────────────────────────────────────────

enum OperationStatus {
  DRAFT
  WAITING
  READY
  DONE
  CANCELLED
}

// --- Receipts (Incoming) ---

model Receipt {
  id            String          @id @default(cuid())
  reference     String          @unique
  supplier      String?
  locationId    String
  location      Location        @relation(fields: [locationId], references: [id])
  scheduledDate DateTime?
  status        OperationStatus @default(DRAFT)
  notes         String?
  createdById   String
  createdBy     User            @relation(fields: [createdById], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  lines         ReceiptLine[]
}

model ReceiptLine {
  id               String  @id @default(cuid())
  receiptId        String
  receipt          Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  productId        String
  product          Product @relation(fields: [productId], references: [id])
  quantityOrdered  Float
  quantityReceived Float   @default(0)

  @@index([receiptId])
}

// --- Delivery Orders (Outgoing) ---

model DeliveryOrder {
  id            String          @id @default(cuid())
  reference     String          @unique
  customer      String?
  locationId    String
  location      Location        @relation(fields: [locationId], references: [id])
  scheduledDate DateTime?
  status        OperationStatus @default(DRAFT)
  notes         String?
  createdById   String
  createdBy     User            @relation(fields: [createdById], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  lines         DeliveryLine[]
}

model DeliveryLine {
  id                String        @id @default(cuid())
  deliveryOrderId   String
  deliveryOrder     DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
  productId         String
  product           Product       @relation(fields: [productId], references: [id])
  quantityOrdered   Float
  quantityDelivered Float         @default(0)

  @@index([deliveryOrderId])
}

// --- Internal Transfers ---

model InternalTransfer {
  id             String          @id @default(cuid())
  reference      String          @unique
  fromLocationId String
  fromLocation   Location        @relation("TransferFrom", fields: [fromLocationId], references: [id])
  toLocationId   String
  toLocation     Location        @relation("TransferTo", fields: [toLocationId], references: [id])
  scheduledDate  DateTime?
  status         OperationStatus @default(DRAFT)
  notes          String?
  createdById    String
  createdBy      User            @relation(fields: [createdById], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  lines          TransferLine[]
}

model TransferLine {
  id         String           @id @default(cuid())
  transferId String
  transfer   InternalTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId  String
  product    Product          @relation(fields: [productId], references: [id])
  quantity   Float

  @@index([transferId])
}

// --- Stock Adjustments ---

model StockAdjustment {
  id         String          @id @default(cuid())
  reference  String          @unique
  locationId String
  location   Location        @relation(fields: [locationId], references: [id])
  status     OperationStatus @default(DRAFT)
  reason     String?
  createdById String
  createdBy  User            @relation(fields: [createdById], references: [id])
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  lines      AdjustmentLine[]
}

model AdjustmentLine {
  id              String          @id @default(cuid())
  adjustmentId    String
  adjustment      StockAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  productId       String
  product         Product         @relation(fields: [productId], references: [id])
  recordedQty     Float
  countedQty      Float
  difference      Float

  @@index([adjustmentId])
}

// ─── Move History (Stock Ledger) ────────────────────────────────────────────

enum MoveType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
}

model MoveHistory {
  id             String   @id @default(cuid())
  reference      String
  moveType       MoveType
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  fromLocationId String?
  fromLocation   Location? @relation("MoveFrom", fields: [fromLocationId], references: [id])
  toLocationId   String?
  toLocation     Location? @relation("MoveTo", fields: [toLocationId], references: [id])
  quantity       Float
  contact        String?
  date           DateTime @default(now())
  status         String   @default("Done")

  @@index([reference])
  @@index([moveType])
  @@index([productId])
  @@index([date])
}
