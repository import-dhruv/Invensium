# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/coreinventory?schema=public"

# JWT Configuration - CHANGE THESE IN PRODUCTION
JWT_SECRET="CHANGE-ME-TO-A-SECURE-RANDOM-256-BIT-KEY"
JWT_EXPIRES_IN="7d"

# Server Configuration
PORT=3000
NODE_ENV="development"

# Production Security Notes:
# 1. Generate a secure JWT_SECRET using: openssl rand -base64 32
# 2. Use environment-specific database credentials
# 3. Set NODE_ENV="production" for production deployments
# 4. Consider using environment variable management tools like AWS Secrets Manager
