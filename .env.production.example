# Production Environment Configuration
# Copy this file to .env and update with your production values

# Database Configuration
DB_NAME=coreinventory
DB_USER=coreinventory_user
DB_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}?schema=public

# JWT Configuration - CRITICAL: Change these in production
JWT_SECRET=CHANGE-ME-TO-A-SECURE-RANDOM-256-BIT-KEY
JWT_EXPIRES_IN=7d

# Application Configuration
NODE_ENV=production
PORT=3000

# Security Notes:
# 1. Generate JWT_SECRET: openssl rand -base64 32
# 2. Use strong database passwords
# 3. Consider using environment variable management tools
# 4. Never commit this file to version control